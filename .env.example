# Proton Agent Platform Configuration

# ============== Storage Configuration ==============
# Storage type: file, sqlite, postgres
PROTON_STORAGE_TYPE=file

# Path for file-based storage
PROTON_STORAGE_PATH=./data

# SQLite database path (when PROTON_STORAGE_TYPE=sqlite)
# PROTON_SQLITE_PATH=./data/proton.db

# PostgreSQL connection URL (when PROTON_STORAGE_TYPE=postgres)
# PROTON_POSTGRES_URL=postgresql://user:password@localhost:5432/proton

# ============== LLM Provider Configuration ==============
# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-api-key

# Anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============== Server Configuration ==============
# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# ============== Logging ==============
LOG_LEVEL=INFO
